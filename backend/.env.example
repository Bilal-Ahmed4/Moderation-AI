# ── Database ────────────────────────────────────────────────────────────────
# Local Docker: use MONGODB_URL (set automatically by docker-compose)
# MongoDB Atlas (Render / production): use MONGODB_URI instead
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/moderation_platform?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────────────────────────────────────
# Change this to a long random string in production. Never commit the real value.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=60

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey (free tier available)
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Cloudinary (image hosting) ────────────────────────────────────────────────
# Free tier is plenty for a portfolio project.
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev: keep as-is
# Render: replace with your actual frontend URL (no trailing slash)
CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# The first account registered with this email gets role=admin automatically.
# Clear this line after your first login so nobody else can claim admin.
BOOTSTRAP_ADMIN_EMAIL=you@example.com

# ── File uploads ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
